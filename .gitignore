# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# velite build output
.velite
# velite 에셋 출력(이미지 복사·최적화본) — 빌드 산출물이라 추적 안 함
/public/static

# SDD progress ledger (scratch)
.superpowers/

# agent/tooling artifacts (session-local, not part of the project)
/.agents/
# .claude는 세션 로컬이라 무시하되, 공유 프로젝트 스킬(write-post)만 예외로 추적한다.
# (git은 부모 폴더가 무시되면 하위를 재포함 못 하므로 경로별로 풀어준다)
/.claude/*
!/.claude/skills/
/.claude/skills/*
!/.claude/skills/write-post/
skills-lock.json

# obsidian editor UI state (volatile; keep other .obsidian config)
dong-docs/.obsidian/workspace.json

.worktreeinclude
