{
  "name": "dongcoding",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:content": "velite --watch",
    "dev:next": "next dev --turbopack",
    "build": "velite --clean && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "velite": "^0.4.0",
    "vitest": "^4.1.9"
  }
}
