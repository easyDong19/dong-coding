    "@commitlint/config-conventional": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "katex": "^0.17.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
